#!/usr/bin/env bash
set -euo pipefail
if [ $# -lt 1 ]; then
  echo "usage: rover-remote <forward|backward|left|right|spin_left|spin_right|spin_to|scan|stop|status|ping> [speed|angle]" >&2
  exit 1
fi
ACTION="$1"; shift || true
VALUE="${1:-}"

SOCK_DIR="${XDG_RUNTIME_DIR:-/tmp}/rover-remote-ssh"
mkdir -p "$SOCK_DIR"
chmod 700 "$SOCK_DIR" 2>/dev/null || true
CONTROL_PATH="$SOCK_DIR/%r@%h:%p"
SSH=(
  ssh
  -o BatchMode=yes
  -o ConnectTimeout=8
  -o ControlMaster=auto
  -o ControlPersist=120
  -o ControlPath="$CONTROL_PATH"
  roverpi
)

monitor_for_obstacle() {
  local seconds="$1"
  local elapsed=0
  local out
  while [ "$elapsed" -lt "$seconds" ]; do
    out="$(${SSH[@]} ~/rover/bin/rover-drive status 2>&1 || true)"
    if printf "%s\n" "$out" | grep -Eq 'event=STOPPED:OBSTACLE|error=ERR:OBSTACLE'; then
      echo "obstacle=detected"
      echo "auto_scan=triggered reason=STOPPED:OBSTACLE"
      ${SSH[@]} ~/rover/bin/roverctl.py scan || true
      return 0
    fi
    sleep 1
    elapsed=$((elapsed + 1))
  done
  return 1
}

run_and_maybe_scan() {
  local out
  out="$(${SSH[@]} "bash -lc '~/rover/bin/rover-drive start \"$1\" \"$2\"; ~/rover/bin/rover-drive status'" 2>&1 || true)"
  printf "%s\n" "$out"

  if printf "%s\n" "$out" | grep -Eq 'event=STOPPED:OBSTACLE|error=ERR:OBSTACLE|obstacle=detected'; then
    echo "auto_scan=triggered reason=STOPPED:OBSTACLE"
    ${SSH[@]} ~/rover/bin/roverctl.py scan || true
    return
  fi

  # Keep a short monitoring window so obstacle hits during motion are surfaced in the same Telegram turn.
  monitor_for_obstacle 15 || true
}

case "$ACTION" in
  forward|backward|left|right|spin_left|spin_right)
    if [[ -z "$VALUE" ]]; then VALUE=160; fi
    run_and_maybe_scan "$ACTION" "$VALUE"
    ;;
  spin_to)
    if [[ -z "$VALUE" ]]; then
      echo "spin_to requires angle (0-359)" >&2
      exit 2
    fi
    "${SSH[@]}" ~/rover/bin/roverctl.py spin_to "$VALUE"
    ;;
  scan)
    "${SSH[@]}" ~/rover/bin/roverctl.py scan
    ;;
  stop)
    "${SSH[@]}" ~/rover/bin/rover-drive stop
    ;;
  status)
    "${SSH[@]}" ~/rover/bin/rover-drive status
    ;;
  ping)
    "${SSH[@]}" ~/rover/bin/roverctl.py ping
    ;;
  *)
    echo "unknown action: $ACTION" >&2
    exit 2
    ;;
esac
